// =============================================================================
// MGM Asset Library — Prisma schema (Part 1 initial migration).
//
// Conventions:
//   - All IDs are cuid() strings.
//   - All tables have createdAt / updatedAt where mutable.
//   - Every FK is indexed; every column used in filters or sorts is indexed.
//   - Multilingual fields use Json `{ en, id }`. AssetTranslation is a separate
//     row per locale (see AssetTranslation).
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  // Keep the generated client lean for serverless-friendly builds.
  previewFeatures = ["fullTextSearch"]
  // Bundle engines for both the CI runner (OpenSSL 1.1.x) and the
  // Debian bookworm runtime containers (OpenSSL 3.0.x).
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Locale {
  en
  id
}

enum AssetEngine {
  UNITY
  UNREAL
  ENGINE_AGNOSTIC
}

enum AssetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETED
}

enum AnalysisStatus {
  PENDING
  ANALYZING
  READY
  FAILED
}

enum AvStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
}

enum AssetFileKind {
  UNITYPACKAGE
  UPLUGIN
  UPROJECT
  FBX
  OBJ
  GLB
  GLTF
  BLEND
  MAYA
  TEXTURE_2D
  SPRITE
  AUDIO
  VIDEO
  ANIMATION
  SHADER
  SCRIPT_CS
  SCRIPT_CPP
  SCRIPT_PY
  DOCUMENT
  ARCHIVE
  OTHER
}

enum CommentKind {
  COMMENT
  ISSUE
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum ReportCategory {
  MALICIOUS_FILE
  BROKEN_ASSET
}

enum ReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

enum AssetRequestStatus {
  SENT
  IN_REVIEW
  PENDING
  APPROVED
  REJECTED
}

enum DownloadSource {
  WEB
  UNITY
  UNREAL
}

/// Locked taxonomy — see Part 3 §8.1. The enum value is the on-the-wire `type`
/// in WebSocket envelopes and webhook payloads, so DO NOT rename existing
/// entries; only add to the end of the list.
enum NotificationType {
  COMMENT_CREATED
  COMMENT_REPLY
  ISSUE_CREATED
  ISSUE_STATUS_CHANGED
  REQUEST_CREATED
  REQUEST_STATUS_CHANGED
  REPORT_CREATED
  REPORT_RECEIVED_FOR_YOUR_ASSET
  FEATURED_FEATURED
  VERSION_PUBLISHED
  ANALYZER_FAILED
  AV_INFECTED_WARNING
  AV_INFECTED_ADMIN_ALERT
  ADMIN_PROMOTED
  ADMIN_DEMOTED
}

/// Concrete moderation actions an admin can take while actioning a report.
/// Stored on AuditLog metadata; not currently used as a Postgres column.
enum ReportActionKind {
  NOTHING
  ARCHIVE_ASSET
  DELETE_ASSET
  FORCE_DELETE_ASSET
}

// -----------------------------------------------------------------------------
// User
// -----------------------------------------------------------------------------

/// Application user. Authoritative identity lives in Keycloak; this row is
/// upserted on first authenticated request, keyed by `keycloakSub`.
model User {
  id           String    @id @default(cuid())
  keycloakSub  String    @unique
  email        String    @unique
  displayName  String
  locale       Locale    @default(en)
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  assetsOwned        Asset[]            @relation("AssetOwner")
  libraryItems       LibraryItem[]
  downloads          Download[]
  comments           Comment[]
  reports            Report[]
  requests           AssetRequest[]
  notifications      Notification[]
  pluginTokens       PluginDeviceToken[]
  auditLogs          AuditLog[]         @relation("AuditActor")
  settingsUpdated    Setting[]          @relation("SettingUpdater")
  editorMedia        EditorMediaUpload[]

  @@index([email])
  @@index([keycloakSub])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Asset / AssetTranslation / AssetVersion / AssetFile / Compat / Dependency
// -----------------------------------------------------------------------------

/// A published unit (Unity package, Unreal plugin, FBX bundle, etc.).
/// Title is single-language; localized text lives in AssetTranslation.
model Asset {
  id                   String       @id @default(cuid())
  slug                 String       @unique
  title                String
  ownerId              String
  categoryId           String
  licenseId            String
  engine               AssetEngine
  status               AssetStatus  @default(DRAFT)
  thumbnailKey         String?      // required at publish; nullable for DRAFT
  /// Map of `<size> → s3Key` for the responsive variants emitted by the
  /// thumbnail-variants worker (see Part 3 §6.1).
  thumbnailVariants    Json?
  /// 3D auto-rendered preview produced from the converted GLB (Part 3 §6.2).
  /// Null until the gltf-convert + thumbnail-render pipeline finishes.
  thumbnailAutoGeneratedKey String?
  requiresEmptyProject Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  publishedAt          DateTime?
  archivedAt           DateTime?    // start of the 30-day purge clock

  owner       User              @relation("AssetOwner", fields: [ownerId], references: [id])
  category    Category          @relation(fields: [categoryId], references: [id])
  license     License           @relation(fields: [licenseId], references: [id])
  translations AssetTranslation[]
  versions    AssetVersion[]
  tags        AssetTag[]
  libraryItems LibraryItem[]
  downloads   Download[]
  comments    Comment[]
  reports     Report[]
  featured    FeaturedSlot?
  stats       AssetStats?
  dailyStats  DownloadDaily[]

  @@index([status])
  @@index([engine])
  @@index([categoryId])
  @@index([licenseId])
  @@index([ownerId])
  @@index([publishedAt(sort: Desc)])
  @@index([archivedAt])
  @@map("assets")
}

/// Per-locale text for an asset. Resolver falls back to first-created locale
/// when the requested locale is missing.
model AssetTranslation {
  id               String   @id @default(cuid())
  assetId          String
  locale           Locale
  shortDescription String
  /// TipTap JSON document (long-form description).
  longDescription  Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, locale])
  @@index([assetId])
  @@map("asset_translations")
}

/// A specific semver-tagged release of an Asset. Exactly one row per asset has
/// `isLatest = true` (enforced at the service layer in a transaction).
model AssetVersion {
  id             String         @id @default(cuid())
  assetId        String
  semver         String
  /// TipTap JSON keyed by locale: `{ en: {...}, id: {...} }`.
  releaseNotes   Json
  s3Prefix       String         // e.g. assets/{assetId}/v{semver}/
  bytesTotal     BigInt         @default(0)
  fileCount      Int            @default(0)
  /// Manifest tree produced by the analyzer (files, sizes, kinds).
  manifest       Json?
  analysisStatus AnalysisStatus @default(PENDING)
  avStatus       AvStatus       @default(PENDING)
  isLatest       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  publishedAt    DateTime?

  asset         Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  files         AssetFile[]
  compatibility EngineCompatibility[]
  dependencies  AssetDependency[]
  downloads     Download[]

  @@unique([assetId, semver])
  @@index([assetId])
  @@index([analysisStatus])
  @@index([avStatus])
  @@index([isLatest])
  @@map("asset_versions")
}

/// One row per file inside a version, populated by the analyzer worker.
model AssetFile {
  id           String        @id @default(cuid())
  versionId    String
  s3Key        String
  relativePath String
  bytes        BigInt
  mimeType     String
  kind         AssetFileKind
  /// Kind-specific metadata: polycount, animationLengthSeconds, etc.
  meta         Json?
  createdAt    DateTime      @default(now())

  version   AssetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  downloads Download[]

  @@index([versionId])
  @@index([kind])
  @@map("asset_files")
}

/// Engine/version/pipeline/target compatibility for an AssetVersion.
/// Multiple rows per version (e.g. Unity 6000.1.14f1 URP-only + 6000.0.2f1 URP+HDRP).
model EngineCompatibility {
  id              String   @id @default(cuid())
  versionId       String
  engineVersion   String   // e.g. "6000.1.14f1", "5.4"
  /// Unity render pipelines (URP|HDRP|SRP|BUILT_IN). Nullable for non-Unity.
  renderPipelines String[]
  /// Platform targets (WINDOWS|MAC|LINUX|IOS|ANDROID|CONSOLE|WEB|VR).
  targets         String[]
  createdAt       DateTime @default(now())

  version AssetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([engineVersion])
  @@map("engine_compatibility")
}

/// External dependency declared by the manifest (UPM, Unreal plugin, npm, …).
model AssetDependency {
  id        String   @id @default(cuid())
  versionId String
  name      String
  version   String?
  source    String   // free-form: "UnityPackageManager", "UnrealPlugin", "npm", …
  createdAt DateTime @default(now())

  versionRef AssetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([name])
  @@map("asset_dependencies")
}

// -----------------------------------------------------------------------------
// Category / Tag / License
// -----------------------------------------------------------------------------

/// Admin-curated category (fixed list, multilingual labels).
model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  /// `{ en: "...", id: "..." }`.
  name      Json
  iconKey   String?  // S3 key for icon
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]

  @@index([sortOrder])
  @@index([isActive])
  @@map("categories")
}

/// Free-form tag created during publish.
model Tag {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  createdAt   DateTime @default(now())

  assets AssetTag[]
  usage  TagUsage?

  @@map("tags")
}

/// M:N join between Asset and Tag.
model AssetTag {
  assetId String
  tagId   String

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([tagId])
  @@map("asset_tags")
}

/// Admin-managed license template (MIT, CC0, Commercial, …).
model License {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  /// `{ en, id }` short description.
  description Json
  /// `{ en, id }` full legal text.
  fullText    Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]

  @@index([sortOrder])
  @@index([isActive])
  @@map("licenses")
}

// -----------------------------------------------------------------------------
// LibraryItem / Download
// -----------------------------------------------------------------------------

/// A user's saved-library entry. Auto-created on first download.
model LibraryItem {
  id      String   @id @default(cuid())
  userId  String
  assetId String
  hidden  Boolean  @default(false)
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
  @@map("library_items")
}

/// Download event (analytics). `fileId` is set when the user picked a specific
/// file inside the popup; null when they downloaded the whole version.
model Download {
  id        String         @id @default(cuid())
  userId    String
  assetId   String
  versionId String
  fileId    String?
  ipHash    String         // sha256(ip + salt)
  country   String?        // ISO-3166-1 alpha-2, optional GeoIP enrichment
  userAgent String         // truncated to ~512 chars
  source    DownloadSource
  createdAt DateTime       @default(now())

  user    User         @relation(fields: [userId], references: [id])
  asset   Asset        @relation(fields: [assetId], references: [id])
  version AssetVersion @relation(fields: [versionId], references: [id])
  file    AssetFile?   @relation(fields: [fileId], references: [id])

  @@index([assetId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([versionId])
  @@index([source])
  @@map("downloads")
}

// -----------------------------------------------------------------------------
// Comment / Issue (shared table)
// -----------------------------------------------------------------------------

/// Threaded discussion under an asset. Top-level rows may have kind=ISSUE with
/// a status field; replies inside an issue thread are kind=COMMENT. Depth is
/// capped at 5 (enforced at the service layer).
model Comment {
  id        String       @id @default(cuid())
  assetId   String
  authorId  String
  parentId  String?
  kind      CommentKind  @default(COMMENT)
  /// Restricted TipTap JSON (Lite schema enforced at API layer).
  body      Json
  /// Meaningful only when kind=ISSUE on a top-level row.
  status    IssueStatus?
  depth     Int          @default(0)
  editedAt  DateTime?
  deletedAt DateTime?    // soft delete (admin-only)
  createdAt DateTime     @default(now())

  asset   Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([assetId, createdAt(sort: Desc)])
  @@index([parentId])
  @@index([authorId])
  @@index([kind])
  @@map("comments")
}

// -----------------------------------------------------------------------------
// Report
// -----------------------------------------------------------------------------

/// User-submitted report against an asset (malicious / broken / etc.).
model Report {
  id          String         @id @default(cuid())
  reporterId  String
  assetId     String
  category    ReportCategory
  notes       String
  status      ReportStatus   @default(OPEN)
  adminNotes  String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  reporter User  @relation(fields: [reporterId], references: [id])
  asset    Asset @relation(fields: [assetId], references: [id])

  @@index([status])
  @@index([assetId])
  @@index([reporterId])
  @@map("reports")
}

// -----------------------------------------------------------------------------
// AssetRequest
// -----------------------------------------------------------------------------

/// "Please source this asset for us" — submitted by users, triaged by admins.
model AssetRequest {
  id            String             @id @default(cuid())
  requesterId   String
  assetLink     String
  assetType     String
  intendedUse   String
  price         Decimal?           @db.Decimal(12, 2)
  notes         String?
  status        AssetRequestStatus @default(SENT)
  adminComment  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  requester User @relation(fields: [requesterId], references: [id])

  @@index([status])
  @@index([requesterId])
  @@map("asset_requests")
}

// -----------------------------------------------------------------------------
// FeaturedSlot
// -----------------------------------------------------------------------------

/// Hero carousel slot on the landing page. Hard cap of 5 active rows enforced
/// at the service layer.
model FeaturedSlot {
  id                      String   @id @default(cuid())
  assetId                 String   @unique
  sortOrder               Int      @unique
  customBannerKey         String?
  customTitle             String?
  /// `{ en, id }` override for short description, optional.
  customShortDescription  Json?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
  @@map("featured_slots")
}

// -----------------------------------------------------------------------------
// Notification (in-app inbox)
// -----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  /// Context-specific payload (assetId, commentId, requestId, …).
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// PluginDeviceToken
// -----------------------------------------------------------------------------

/// Long-lived bearer token issued by our backend (not Keycloak) to a Unity or
/// Unreal editor plugin. Stored hashed (HMAC-SHA256 with PLUGIN_TOKEN_PEPPER).
model PluginDeviceToken {
  id          String    @id @default(cuid())
  userId      String
  deviceLabel String
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("plugin_device_tokens")
}

// -----------------------------------------------------------------------------
// AuditLog
// -----------------------------------------------------------------------------

/// Mutating admin actions. Retention: 30 days (purged by cron in Part 3).
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String   // e.g. "asset.delete", "featured.reorder"
  subjectType String
  subjectId   String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([subjectType, subjectId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Setting (admin-tunable runtime config)
// -----------------------------------------------------------------------------

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy User? @relation("SettingUpdater", fields: [updatedById], references: [id])

  @@map("settings")
}

// -----------------------------------------------------------------------------
// Part 3 additions: rollups, GC bookkeeping, tag usage cache
// -----------------------------------------------------------------------------

/// Bookkeeping for editor-media (TipTap inline) uploads. The
/// `editor-media-gc` cron compares this table against the set of keys
/// referenced by any AssetTranslation.longDescription and prunes orphans
/// older than 7 days.
model EditorMediaUpload {
  id          String   @id @default(cuid())
  key         String   @unique
  uploaderId  String
  mimeType    String?
  bytes       BigInt   @default(0)
  /// Flipped to `true` by the GC after we've confirmed it's referenced; the
  /// worker only deletes keys that are STILL unreferenced AND older than 7d.
  referenced  Boolean  @default(false)
  createdAt   DateTime @default(now())

  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId])
  @@index([referenced, createdAt])
  @@map("editor_media_uploads")
}

/// Per-asset rollup of download/save metrics. Single row per asset, upserted
/// every 24h by the analytics-rollup cron. AssetDetail reads `stats.{*}` from
/// here, never from `Download` directly.
model AssetStats {
  assetId           String   @id
  totalDownloads    Int      @default(0)
  totalSaves        Int      @default(0)
  last7dDownloads   Int      @default(0)
  last30dDownloads  Int      @default(0)
  updatedAt         DateTime @default(now()) @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("asset_stats")
}

/// Daily per-asset aggregate. Backs the admin analytics page (Part 4) and is
/// retained forever; raw `Download` rows are purged after
/// DOWNLOAD_RAW_RETENTION_DAYS.
model DownloadDaily {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  assetId     String
  count       Int      @default(0)
  uniqueUsers Int      @default(0)
  /// `{ "US": 12, "ID": 4, … }`
  byCountry   Json     @default("{}")
  /// `{ "WEB": 12, "UNITY": 4, "UNREAL": 0 }`
  bySource    Json     @default("{}")
  createdAt   DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
  @@index([date])
  @@map("download_daily")
}

/// Live denormalized usage count for tag autocomplete. Recomputed
/// incrementally by the search-index batch worker.
model TagUsage {
  tagId      String   @id
  usageCount Int      @default(0)
  updatedAt  DateTime @default(now()) @updatedAt

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([usageCount(sort: Desc)])
  @@map("tag_usage")
}

// -----------------------------------------------------------------------------
// Part 4 additions: storage accounting
// -----------------------------------------------------------------------------

/// Per-bucket+prefix daily snapshot (e.g. `assets/__derived__/`). Powers the
/// admin dashboard's storage block. Populated by the `storage-rollup` cron.
model StorageDaily {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  bucket      String
  prefix      String
  bytes       BigInt   @default(0)
  objectCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([date, bucket, prefix])
  @@index([date])
  @@map("storage_daily")
}

/// Per-user daily byte usage (sum of bytes for assets the user owns).
model StorageUserDaily {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  userId    String
  bytes     BigInt   @default(0)
  /// Number of assets contributing to the total.
  assetCount Int     @default(0)
  createdAt DateTime @default(now())

  @@unique([date, userId])
  @@index([date])
  @@index([userId])
  @@map("storage_user_daily")
}

/// Per-asset daily byte usage. Tracks how much each asset costs on storage.
model StorageAssetDaily {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  assetId   String
  bytes     BigInt   @default(0)
  createdAt DateTime @default(now())

  @@unique([date, assetId])
  @@index([date])
  @@index([assetId])
  @@map("storage_asset_daily")
}
