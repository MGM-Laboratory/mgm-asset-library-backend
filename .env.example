# =============================================================================
# MGM Asset Library — Backend Environment Reference
# -----------------------------------------------------------------------------
# Copy this file to `.env` for local development. Every key listed here is
# validated by `src/config/env.schema.ts` at boot — missing or malformed
# values will cause the process to exit immediately.
# =============================================================================

# ─────────── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development                    # development | staging | production
PROCESS_ROLE=api                        # api | worker (Part 3 §2.2 — controls Nest startup)
PORT=4000
LOG_LEVEL=info                          # trace | debug | info | warn | error | fatal
TRUST_PROXY=true                        # honour X-Forwarded-* from SWAG/nginx
CORS_ORIGINS=http://localhost:3000,https://asset.labmgm.org
PUBLIC_BASE_URL=https://asset-api.labmgm.org
METRICS_ALLOW_CIDRS=                    # comma-separated CIDR allow-list for /metrics; blank = admin only

# ─────────── Postgres (Prisma) ───────────────────────────────────────────────
DATABASE_URL=postgresql://mgm:mgm@localhost:5432/mgm_asset_library?schema=public

# ─────────── MongoDB (Mongoose) ──────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017/mgm_asset_library

# ─────────── Redis (BullMQ + cache) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────── Keycloak (external — managed by ops team) ───────────────────────
KEYCLOAK_ISSUER_URL=https://auth.labmgm.org/realms/mgm
KEYCLOAK_AUDIENCE=mgm-asset-library
KEYCLOAK_JWKS_URI=https://auth.labmgm.org/realms/mgm/protocol/openid-connect/certs
KEYCLOAK_ALGORITHMS=RS256
KEYCLOAK_CLOCK_TOLERANCE_SEC=30
KEYCLOAK_JWKS_CACHE_TTL_SEC=3600
ADMIN_BOOTSTRAP_EMAIL=admin@labmgm.org

# ─────────── Plugin device tokens (Unity / Unreal) ───────────────────────────
PLUGIN_TOKEN_TTL_DAYS=90
PLUGIN_TOKEN_PEPPER=                    # secret for HMAC; REQUIRED in production

# ─────────── S3 (object storage) ─────────────────────────────────────────────
S3_REGION=us-east-1
S3_ENDPOINT=                            # blank for AWS; e.g. http://minio:9000 for local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false               # true for MinIO and most S3-compatible vendors
S3_BUCKET_ASSETS=mgm-asset-library-assets
S3_BUCKET_THUMBS=mgm-asset-library-thumbs
S3_BUCKET_EDITOR_MEDIA=mgm-asset-library-editor
S3_PRESIGN_EXPIRES_SEC=3600

# ─────────── Meilisearch ─────────────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=

# ─────────── Mail (Mailtrap SMTP) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MGM Asset Library <no-reply@labmgm.org>"

# ─────────── n8n outbound webhook ────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=                     # body signed via HMAC-SHA256

# ─────────── Sentry (error tracking) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# ─────────── Background tools (worker container only) ───────────────────────
BLENDER_BIN=/usr/bin/blender
CLAMSCAN_BIN=/usr/bin/clamscan
FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
GLTF_PIPELINE_BIN=/usr/local/bin/gltf-pipeline
GLTFPACK_BIN=/usr/local/bin/gltfpack
PYANALYZE_VENV=/opt/mgm-py              # Python venv with trimesh / pyassimp / pillow
HDRI_PATH=/opt/mgm/hdri/studio_small_03.hdr

# ─────────── ClamAV daemon (worker uses INSTREAM via TCP) ────────────────────
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310
CLAMD_TIMEOUT_MS=120000
CLAMD_MAX_STREAM_BYTES=524288000        # 500 MiB; larger files spill to a temp file scan

# ─────────── Worker job limits ───────────────────────────────────────────────
ANALYZE_TIMEOUT_SEC=300                 # per-file analyzer wall clock
GLTF_CONVERT_TIMEOUT_SEC=600            # Blender/gltfpack wall clock
GLTFPACK_KTX2=false                     # set true if your gltfpack was built with toktx
WORKER_SCRATCH_DIR=/tmp/mgm-analyze

# ─────────── Search indexer ──────────────────────────────────────────────────
SEARCH_INDEX_BATCH_INTERVAL_MS=5000

# ─────────── Retention windows (days) ────────────────────────────────────────
ARCHIVE_PURGE_DAYS=30
AUDIT_LOG_RETENTION_DAYS=30
WEBHOOK_LOG_RETENTION_DAYS=30
DOWNLOAD_RAW_RETENTION_DAYS=90

# ─────────── Feature flags ───────────────────────────────────────────────────
FEATURE_SWAGGER_PUBLIC=false            # if true, /docs is publicly reachable in production
FEATURE_QUEUE_DASHBOARD=true            # mounts @bull-board at /admin/queues (admin-only)
